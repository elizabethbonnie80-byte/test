# Edge-function secrets — copy to `supabase/.env` and fill in with REAL keys.
#
# `supabase/.env` is gitignored (it holds real API keys — NEVER commit it). Load it by serving the
# functions with the env-file:  `pnpm functions:serve`  (= supabase functions serve --env-file supabase/.env).
#
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are auto-injected by the runtime — only
# the custom vars below need to live here. For hosted deploys use `supabase secrets set …` instead.

# Claude API key for the anti-contact AI 2nd layer (console.anthropic.com). If absent, scanContact
# falls back to the regex-only RPC and the DB triggers remain the backstop — the app still works.
# Use a NEW key; never reuse/commit the old Bubble key (rotate it — OQ#6).
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key for the notify-email channel (resend.com).
RESEND_API_KEY=re_...

# Email "From" for notify-email. The domain MUST be verified in Resend (until then use their shared
# testing sender `onboarding@resend.dev`, which only delivers to your own Resend account address).
NOTIFY_FROM=LenderMatch <no-reply@your-verified-domain>
