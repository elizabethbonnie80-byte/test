# Next.js app environment — copy to `.env.local` and fill in.
#
# For LOCAL development the values below are the well-known Supabase local defaults (public dev keys,
# NOT secrets) that `pnpm db:start` prints — `.env.local` ships with them already, so you usually don't
# need to touch this. For a hosted deployment, set these in the deployment environment (Vercel/CI),
# never in a committed file, and use that project's own URL + anon key.

# Supabase project API URL (local default shown).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabase anon/publishable key — safe to expose to the browser (RLS enforces access).
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# NOTE: never put the service-role key here — it is server-side only (edge functions / tooling).
